<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="estate.EstateDashboard">
        <div class="o_estate_dashboard">
            <section class="o_estate_dashboard_header">
                <div>
                    <p class="o_estate_dashboard_eyebrow">Real Estate</p>
                    <h1>Dashboard</h1>
                    <p class="o_estate_dashboard_subtitle">Operational overview for properties, visits and offers.</p>
                </div>
                <button class="o_estate_user_chip" type="button" t-on-click="openProfile">
                    <img t-att-src="'/web/image/res.users/' + session.uid + '/avatar_128'" alt="User avatar"/>
                    <span t-esc="userName"/>
                </button>
            </section>

            <section class="o_estate_dashboard_actions">
                <button class="btn btn-primary" type="button" t-on-click="openProperties">Open Properties</button>
                <button class="btn btn-secondary" type="button" t-on-click="openProfile">Open Profile</button>
            </section>

            <section class="o_estate_metric_grid">
                <t t-foreach="cards" t-as="card" t-key="card.title">
                    <article class="o_estate_metric_card">
                        <p class="o_estate_metric_title" t-esc="card.title"/>
                        <h2 t-esc="card.value"/>
                        <p class="o_estate_metric_detail" t-esc="card.detail"/>
                    </article>
                </t>
            </section>

            <section class="o_estate_panel_grid">
                <t t-foreach="panels" t-as="panel" t-key="panel.title">
                    <article class="o_estate_panel">
                        <h3 t-esc="panel.title"/>
                        <ul>
                            <t t-foreach="panel.items" t-as="item" t-key="item">
                                <li t-esc="item"/>
                            </t>
                        </ul>
                    </article>
                </t>
            </section>
        </div>
    </t>

    <t t-name="estate.EstateProfile">
        <div class="o_estate_profile_page">
            <div class="o_estate_profile_toolbar">
                <button class="btn btn-secondary" type="button" t-on-click="backToDashboard">Back to Dashboard</button>
            </div>

            <t t-if="state.loading">
                <div class="o_estate_profile_loading">Loading profile...</div>
            </t>
            <t t-else="">
                <section class="o_estate_profile_header">
                    <img t-att-src="avatarUrl" alt="User avatar"/>
                    <div>
                        <p class="o_estate_dashboard_eyebrow">User Profile</p>
                        <h1 t-esc="state.user.name"/>
                        <p class="o_estate_dashboard_subtitle">Read-only summary of the current user in Odoo.</p>
                    </div>
                </section>

                <section class="o_estate_profile_grid">
                    <article class="o_estate_profile_card">
                        <h3>Account</h3>
                        <dl>
                            <dt>Login</dt>
                            <dd t-esc="state.user.login or '-'"/>
                            <dt>Email</dt>
                            <dd t-esc="state.user.email or '-'"/>
                        </dl>
                    </article>

                    <article class="o_estate_profile_card">
                        <h3>Contact</h3>
                        <dl>
                            <dt>Phone</dt>
                            <dd t-esc="state.user.phone or '-'"/>
                            <dt>Mobile</dt>
                            <dd t-esc="state.user.mobile or '-'"/>
                        </dl>
                    </article>

                    <article class="o_estate_profile_card">
                        <h3>Preferences</h3>
                        <dl>
                            <dt>Language</dt>
                            <dd t-esc="state.user.lang or '-'"/>
                            <dt>Timezone</dt>
                            <dd t-esc="state.user.tz or '-'"/>
                        </dl>
                    </article>
                </section>
            </t>
        </div>
    </t>

</templates>
