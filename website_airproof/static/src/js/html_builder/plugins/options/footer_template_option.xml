<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="website_airproof.FooterTemplateOption" t-inherit="website.FooterTemplateOption" t-inherit-mode="extension">
        <xpath expr="//BuilderSelect[@action=&quot;'websiteConfigFooter'&quot;]" position="inside">
            <BuilderSelectItem title.translate="Aiproof"
                actionParam="{
                        view: 'website_airproof.footer',
                        vars: { 'footer-template': 'airproof' }
                    }"
            >
                <Img src="'/website_airproof/static/src/img/wbuilder/template-footer-opt.svg'" class="'w-100'"/>
            </BuilderSelectItem>
        </xpath>
    </t>
</templates>
